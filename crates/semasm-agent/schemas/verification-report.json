{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerificationReport",
  "description": "Full agent verification report: one compose, no pending mutation.",
  "type": "object",
  "properties": {
    "alias_analysis": {
      "description": "Region/Alias Evidence v1 (ADR 0006). Absent when the contract has no\n`[function.memory]` block or the target cannot collect effects.",
      "anyOf": [
        {
          "$ref": "#/$defs/AliasAnalysisReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "behavior": {
      "description": "Behavioral harness results when execution was allowed.",
      "anyOf": [
        {
          "$ref": "#/$defs/HarnessReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "behavior_oracle": {
      "description": "Named, versioned behavioral oracle for the recognized routine shape.\n\nPresent when the contract matches a builtin harness profile. Equality\nbehavior for golden shapes (e.g. count-equal-byte) is proven by this\noracle plus vectors — not by weak contract `ensures` alone.",
      "anyOf": [
        {
          "$ref": "#/$defs/BehaviorOracle"
        },
        {
          "type": "null"
        }
      ]
    },
    "contract_digest": {
      "description": "SHA-256 digest of the contract file bytes (`sha256:` + hex).",
      "type": "string"
    },
    "contract_expressions": {
      "description": "Contract Expression Semantics v1 (ADR 0007). Absent when no subset\nexpression was attempted (all `not_evaluated`).",
      "anyOf": [
        {
          "$ref": "#/$defs/ContractExprReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "executable": {
      "description": "Post-link executable gate result.",
      "$ref": "#/$defs/ExecutableGate"
    },
    "isolation": {
      "description": "How execution was isolated (or that only static gates ran).",
      "$ref": "#/$defs/ExecutionIsolation"
    },
    "region_access": {
      "description": "Region Access Evidence v1 (ADR 0011). Absent without `[function.memory]`\nor when effects cannot be collected.",
      "anyOf": [
        {
          "$ref": "#/$defs/RegionAccessReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "routine_symbol": {
      "description": "Routine symbol under verification.",
      "type": "string"
    },
    "schema_version": {
      "description": "Agent verification-report schema version (`MAJOR.MINOR`).",
      "type": "string"
    },
    "semantic": {
      "description": "Static semantic gate results.",
      "$ref": "#/$defs/SemanticGates"
    },
    "source_digest": {
      "description": "SHA-256 digest of the candidate source bytes (`sha256:` + hex).",
      "type": "string"
    },
    "status": {
      "description": "Aggregate status derived from stage results.",
      "$ref": "#/$defs/VerificationStatus"
    },
    "target": {
      "description": "Target identity name.",
      "type": "string"
    },
    "tool_version": {
      "description": "Tool identity string (`semasm MAJOR.MINOR.PATCH`).",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "status",
    "target",
    "routine_symbol",
    "isolation",
    "tool_version",
    "contract_digest",
    "source_digest",
    "semantic",
    "executable"
  ],
  "$defs": {
    "AccessMode": {
      "description": "Load vs store.",
      "oneOf": [
        {
          "description": "Memory load.",
          "type": "string",
          "const": "load"
        },
        {
          "description": "Memory store.",
          "type": "string",
          "const": "store"
        }
      ]
    },
    "AliasAnalysisReport": {
      "description": "Full alias-analysis block for [`crate` consumers / VerificationReport].",
      "type": "object",
      "properties": {
        "assumptions": {
          "description": "Explicit honesty assumptions.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "model": {
          "description": "Evidence model id.",
          "type": "string"
        },
        "relations": {
          "description": "Per-relation rows.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/AliasRelationEvidence"
          }
        },
        "status": {
          "description": "Aggregate slice status.",
          "$ref": "#/$defs/AliasStatus"
        },
        "unknown_memory_accesses": {
          "description": "Count of unmodeled (non-stack) memory accesses.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "unresolved_obligations": {
          "description": "Caller obligations not discharged by static proof (ADR 0010).",
          "type": "array",
          "items": {
            "$ref": "#/$defs/VerificationObligation"
          }
        }
      },
      "required": [
        "model",
        "status",
        "relations",
        "unknown_memory_accesses",
        "assumptions"
      ]
    },
    "AliasRelationEvidence": {
      "description": "Per-relation evidence row.",
      "type": "object",
      "properties": {
        "basis": {
          "description": "Short proof basis or reason string.",
          "type": "string"
        },
        "evidence_basis": {
          "description": "Typed evidence basis (ADR 0010).",
          "$ref": "#/$defs/RelationEvidenceBasis",
          "default": "unknown"
        },
        "left": {
          "description": "Left region name.",
          "type": "string"
        },
        "observed": {
          "description": "Observed relation status.",
          "$ref": "#/$defs/RelationObserved"
        },
        "required": {
          "description": "Required relation from the contract.",
          "type": "string"
        },
        "right": {
          "description": "Right region name.",
          "type": "string"
        }
      },
      "required": [
        "left",
        "right",
        "required",
        "observed",
        "basis"
      ]
    },
    "AliasStatus": {
      "description": "Aggregate status for the alias evidence slice.",
      "oneOf": [
        {
          "description": "Every required relation was statically proven and no unknown accesses.",
          "type": "string",
          "const": "passed"
        },
        {
          "description": "Required relations are met only via declared caller preconditions\n(and/or mixed with static proofs); no unknowns / contradictions.",
          "type": "string",
          "const": "passed_under_preconditions"
        },
        {
          "description": "Required relation unproven and/or unknown memory accesses present.",
          "type": "string",
          "const": "incomplete"
        },
        {
          "description": "Observed relation contradicts a required one.",
          "type": "string",
          "const": "failed"
        }
      ]
    },
    "BehaviorOracle": {
      "description": "Named deterministic behavioral oracle attached to a verification report.",
      "type": "object",
      "properties": {
        "claim": {
          "description": "Human-readable claim checked by the oracle (not a formal ensures AST).",
          "type": "string"
        },
        "contract": {
          "description": "Contract path or basename supplied to verify.",
          "type": "string"
        },
        "contract_ensures": {
          "description": "Raw `ensures` expressions from the contract (may be weaker than the claim).",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contract_hash": {
          "description": "Short SHA-256 of contract bytes.",
          "type": "string"
        },
        "evidence_hash": {
          "description": "Deterministic hash over oracle identity and vector evidence.",
          "type": "string"
        },
        "id": {
          "description": "Stable oracle id (`builtin.buffer.count_equal_u8`, …).",
          "type": "string"
        },
        "proof_basis": {
          "description": "How equality/behavior was proven for this shape.",
          "$ref": "#/$defs/ProofBasis"
        },
        "vectors_failed": {
          "description": "Vectors that failed (0 when execution was not run).",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "vectors_passed": {
          "description": "Vectors that passed (0 when execution was not run).",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "vectors_total": {
          "description": "Total vectors planned or evaluated.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "version": {
          "description": "Integer profile version for this oracle id.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "version",
        "contract",
        "contract_hash",
        "contract_ensures",
        "proof_basis",
        "claim",
        "vectors_passed",
        "vectors_failed",
        "vectors_total",
        "evidence_hash"
      ]
    },
    "BoundsStatus": {
      "description": "Bounds judgement for one access.",
      "oneOf": [
        {
          "description": "Access fully inside a matched region (static affine).",
          "type": "string",
          "const": "proven_inside"
        },
        {
          "description": "Access fully outside all candidate regions (static affine).",
          "type": "string",
          "const": "proven_outside"
        },
        {
          "description": "Might escape; not proven either way.",
          "type": "string",
          "const": "may_escape"
        },
        {
          "description": "Address not modeled enough to judge.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "ContractExprEvidence": {
      "description": "One evaluated (or skipped) expression row.",
      "type": "object",
      "properties": {
        "basis": {
          "description": "Short basis string.",
          "type": "string"
        },
        "judgement": {
          "description": "Judgement.",
          "$ref": "#/$defs/ExprJudgement"
        },
        "role": {
          "description": "requires / ensures.",
          "$ref": "#/$defs/ExprRole"
        },
        "source": {
          "description": "Original source text.",
          "type": "string"
        }
      },
      "required": [
        "role",
        "source",
        "judgement",
        "basis"
      ]
    },
    "ContractExprReport": {
      "description": "Full contract-expression block for VerificationReport.",
      "type": "object",
      "properties": {
        "assumptions": {
          "description": "Explicit honesty assumptions.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expressions": {
          "description": "Per-expression rows (including not_evaluated).",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContractExprEvidence"
          }
        },
        "model": {
          "description": "Evidence model id.",
          "type": "string"
        },
        "status": {
          "description": "Aggregate slice status.",
          "$ref": "#/$defs/ContractExprStatus"
        }
      },
      "required": [
        "model",
        "status",
        "expressions",
        "assumptions"
      ]
    },
    "ContractExprStatus": {
      "description": "Aggregate status for the contract-expression slice.",
      "oneOf": [
        {
          "description": "Every attempted expression was proven true.",
          "type": "string",
          "const": "passed"
        },
        {
          "description": "Attempted expressions hold only under declared caller preconditions.",
          "type": "string",
          "const": "passed_under_preconditions"
        },
        {
          "description": "At least one attempted expression could not be decided.",
          "type": "string",
          "const": "incomplete"
        },
        {
          "description": "At least one attempted expression was proven false.",
          "type": "string",
          "const": "failed"
        }
      ]
    },
    "Coverage": {
      "description": "Instruction-level coverage counts (unknown ≠ verified).\n\nDecode and lowering gates always use instruction counts here. Byte-level\ndetail belongs in error messages, not in these fields.",
      "type": "object",
      "properties": {
        "modeled": {
          "description": "Instructions with modeled / accepted semantics.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "total": {
          "description": "Total instructions presented to the gate.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "unknown": {
          "description": "Instructions left unknown or unsupported.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "total",
        "modeled",
        "unknown"
      ]
    },
    "ExecutableGate": {
      "description": "Linked-image object-format gate (run only after link).",
      "type": "object",
      "properties": {
        "status": {
          "description": "Whether the linked image is an executable container.",
          "$ref": "#/$defs/GateStatus"
        }
      },
      "required": [
        "status"
      ]
    },
    "ExecutionIsolation": {
      "description": "How candidate/artifact execution was (or was not) isolated.\n\nThis is an honesty field for reports — SemASM does not claim OS sandboxing\n(seccomp / job objects / containers) by default.",
      "oneOf": [
        {
          "description": "No candidate/artifact process was started (static gates only).",
          "type": "string",
          "const": "static_only"
        },
        {
          "description": "Ran under a QEMU user-mode emulator.",
          "type": "string",
          "const": "qemu_user"
        },
        {
          "description": "Ran directly on the build host (no emulator wrapper).",
          "type": "string",
          "const": "native_host"
        }
      ]
    },
    "ExprJudgement": {
      "description": "Per-expression judgement.",
      "oneOf": [
        {
          "description": "Expression evaluated to true under the subset rules.",
          "type": "string",
          "const": "proven_true"
        },
        {
          "description": "Expression evaluated to false under the subset rules.",
          "type": "string",
          "const": "proven_false"
        },
        {
          "description": "True only under an explicit declared precondition (ADR 0010).",
          "type": "string",
          "const": "true_under_precondition"
        },
        {
          "description": "Subset rules apply but a fact was missing / unknown op.",
          "type": "string",
          "const": "incomplete"
        },
        {
          "description": "Out of static subset scope (e.g. unbound postcondition).",
          "type": "string",
          "const": "not_evaluated"
        }
      ]
    },
    "ExprRole": {
      "description": "Where the expression appeared in the contract.",
      "oneOf": [
        {
          "description": "`[[function.requires]]`",
          "type": "string",
          "const": "requires"
        },
        {
          "description": "`[[function.ensures]]`",
          "type": "string",
          "const": "ensures"
        }
      ]
    },
    "GateStatus": {
      "description": "Outcome of a single verification gate.",
      "oneOf": [
        {
          "description": "Gate ran and passed.",
          "type": "string",
          "const": "passed"
        },
        {
          "description": "Gate ran and failed.",
          "type": "string",
          "const": "failed"
        },
        {
          "description": "Gate was not applicable or intentionally not run.",
          "type": "string",
          "const": "skipped"
        }
      ]
    },
    "HarnessReport": {
      "description": "Full harness evaluation report.",
      "type": "object",
      "properties": {
        "all_passed": {
          "description": "True when every case passed.",
          "type": "boolean"
        },
        "cases": {
          "description": "Per-vector results.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/VectorResult"
          }
        }
      },
      "required": [
        "cases",
        "all_passed"
      ]
    },
    "MemoryAccessEvidence": {
      "description": "One memory-access evidence row.",
      "type": "object",
      "properties": {
        "address": {
          "description": "Short address expression for reporting.",
          "type": "string"
        },
        "bounds": {
          "description": "Bounds status.",
          "$ref": "#/$defs/BoundsStatus"
        },
        "evidence_basis": {
          "description": "Evidence basis for this row.",
          "$ref": "#/$defs/RelationEvidenceBasis",
          "default": "unknown"
        },
        "instruction_offset": {
          "description": "Instruction offset when known (0 if unavailable).",
          "type": "integer",
          "format": "uint64",
          "default": 0,
          "minimum": 0
        },
        "operation": {
          "description": "Load or store.",
          "$ref": "#/$defs/AccessMode"
        },
        "permission": {
          "description": "Permission status.",
          "$ref": "#/$defs/PermissionStatus"
        },
        "region": {
          "description": "Matched contract region name, if any.",
          "type": [
            "string",
            "null"
          ]
        },
        "width": {
          "description": "Access width in bytes.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "operation",
        "width",
        "address",
        "bounds",
        "permission"
      ]
    },
    "PermissionStatus": {
      "description": "Permission judgement for one access against a matched region.",
      "oneOf": [
        {
          "description": "Mode allowed by region access declaration.",
          "type": "string",
          "const": "allowed"
        },
        {
          "description": "Mode denied by region access declaration.",
          "type": "string",
          "const": "denied"
        },
        {
          "description": "No matched region / unknown.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "ProofBasis": {
      "description": "How a recognized shape's behavioral claim was established.",
      "oneOf": [
        {
          "description": "Named builtin oracle plus synthesized/evaluated vectors — not contract alone.",
          "type": "string",
          "const": "oracle_and_vectors"
        }
      ]
    },
    "RegionAccessReport": {
      "description": "Full region-access block for VerificationReport (wired in Ra4).",
      "type": "object",
      "properties": {
        "accesses": {
          "description": "Per-access rows.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/MemoryAccessEvidence"
          }
        },
        "accesses_proven_inside": {
          "description": "Accesses with [`BoundsStatus::ProvenInside`].",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "accesses_total": {
          "description": "Total non-stack accesses considered.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "accesses_unknown": {
          "description": "Accesses with unknown address / bounds.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "model": {
          "description": "Evidence model id.",
          "type": "string"
        },
        "status": {
          "description": "Aggregate slice status.",
          "$ref": "#/$defs/RegionAccessStatus"
        }
      },
      "required": [
        "model",
        "status",
        "accesses_total",
        "accesses_proven_inside",
        "accesses_unknown",
        "accesses"
      ]
    },
    "RegionAccessStatus": {
      "description": "Aggregate status for the region-access evidence slice.",
      "oneOf": [
        {
          "description": "Every non-stack access proven inside an allowed region; no unknowns.",
          "type": "string",
          "const": "passed"
        },
        {
          "description": "Affine accesses match declared regions, but bounds rely on symbolic\nregion length (caller obligation); no unknown addresses / denials.",
          "type": "string",
          "const": "passed_under_preconditions"
        },
        {
          "description": "Unknown / may-escape accesses present (or unmatched).",
          "type": "string",
          "const": "incomplete"
        },
        {
          "description": "Proven out-of-bounds or permission denied.",
          "type": "string",
          "const": "failed"
        }
      ]
    },
    "RelationEvidenceBasis": {
      "description": "Why a relation observation is believed (ADR 0010).",
      "oneOf": [
        {
          "description": "Static affine/identity reasoning over the candidate.",
          "type": "string",
          "const": "proven_static"
        },
        {
          "description": "Explicit contract precondition; caller obligation remains.",
          "type": "string",
          "const": "declared_precondition"
        },
        {
          "description": "Reserved: runtime observation.",
          "type": "string",
          "const": "observed_runtime"
        },
        {
          "description": "Reserved: behavioral oracle / test vector.",
          "type": "string",
          "const": "behavioral_test"
        },
        {
          "description": "Reserved: environment assumption.",
          "type": "string",
          "const": "assumed_environment"
        },
        {
          "description": "No usable basis.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "RelationObserved": {
      "description": "Observed status for one declared relation.",
      "oneOf": [
        {
          "description": "Same-base constant affine spans do not overlap (static).",
          "type": "string",
          "const": "proven_disjoint"
        },
        {
          "description": "Identical base (and matching const affine span when comparable).",
          "type": "string",
          "const": "proven_equal"
        },
        {
          "description": "Constant affine containment.",
          "type": "string",
          "const": "proven_contains"
        },
        {
          "description": "Constant affine partial overlap.",
          "type": "string",
          "const": "proven_partial_overlap"
        },
        {
          "description": "Possible overlap; not proven either way (includes distinct param names).",
          "type": "string",
          "const": "may_overlap"
        },
        {
          "description": "Region declaration could not be interpreted.",
          "type": "string",
          "const": "invalid_region"
        },
        {
          "description": "Engine did not evaluate this relation.",
          "type": "string",
          "const": "not_evaluated"
        }
      ]
    },
    "SemanticGates": {
      "description": "Static semantic gates applied to the candidate relocatable object.",
      "type": "object",
      "properties": {
        "abi": {
          "description": "ABI cleanliness gate.",
          "$ref": "#/$defs/GateStatus"
        },
        "capability": {
          "description": "Capability policy (e.g. no syscall in the candidate).",
          "$ref": "#/$defs/GateStatus"
        },
        "control": {
          "description": "Control-flow leaf policy (direct edges only on golden path).\n\nAbsent in older reports; deserializes as [`GateStatus::Passed`].",
          "$ref": "#/$defs/GateStatus",
          "default": "passed"
        },
        "decode": {
          "description": "Decode coverage as instruction counts.",
          "$ref": "#/$defs/Coverage"
        },
        "executable_bytes": {
          "description": "Total executable bytes examined (metadata; not coverage units).",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "lowering": {
          "description": "Lowering coverage over decoded instructions.",
          "$ref": "#/$defs/Coverage"
        },
        "memory": {
          "description": "Memory effects leaf policy (read-only buffer leaves must not store).\n\nAbsent in older reports; deserializes as [`GateStatus::Passed`].",
          "$ref": "#/$defs/GateStatus",
          "default": "passed"
        },
        "object_policy": {
          "description": "Relocatable object, exports, and import policy.",
          "$ref": "#/$defs/GateStatus"
        }
      },
      "required": [
        "object_policy",
        "executable_bytes",
        "decode",
        "lowering",
        "abi",
        "capability"
      ]
    },
    "VectorResult": {
      "description": "Outcome of running the harness against a routine.",
      "type": "object",
      "properties": {
        "expected": {
          "description": "Expected value (decimal string).",
          "type": "string"
        },
        "name": {
          "description": "Name of the test vector.",
          "type": "string"
        },
        "observed": {
          "description": "Observed value (decimal string), or `<no output>` on parse failure.",
          "type": "string"
        },
        "passed": {
          "description": "Whether observed matched expected.",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "passed",
        "expected",
        "observed"
      ]
    },
    "VerificationObligation": {
      "description": "One unresolved verification obligation (typically a caller precondition).",
      "type": "object",
      "properties": {
        "kind": {
          "description": "Obligation kind (`regions_disjoint`, `regions_equal`, `regions_contains`).",
          "type": "string"
        },
        "left": {
          "description": "Left region name.",
          "type": "string"
        },
        "owner": {
          "description": "Who must discharge the obligation (`caller`).",
          "type": "string"
        },
        "right": {
          "description": "Right region name.",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "left",
        "right",
        "owner"
      ]
    },
    "VerificationStatus": {
      "description": "Overall verification outcome after composing immutable stage results.",
      "oneOf": [
        {
          "description": "Static gates and all behavioral vectors passed (no open caller obligations).",
          "type": "string",
          "const": "verified"
        },
        {
          "description": "Passed under explicitly declared caller preconditions (ADR 0010).\n\nNot interchangeable with [`Self::Verified`].",
          "type": "string",
          "const": "verified_under_preconditions"
        },
        {
          "description": "A static semantic gate failed.",
          "type": "string",
          "const": "semantic_failed"
        },
        {
          "description": "Linked image failed the executable-container policy.",
          "type": "string",
          "const": "executable_failed"
        },
        {
          "description": "Execution ran but one or more vectors failed.",
          "type": "string",
          "const": "behavior_failed"
        },
        {
          "description": "Static gates passed; execution was not opted in.",
          "type": "string",
          "const": "execution_denied"
        }
      ]
    }
  }
}
